{% extends 'base.html.twig' %}

{% block title %}Solution, Stratégie et Sens | Direction et management de transition{% endblock %}

{% block meta_description %}Direction de transition et accompagnement strategique pour les structures sociales, medico-sociales et sanitaires. Solution, Strategie et Sens intervient en management de transition, pilotage et stabilisation des organisations.{% endblock %}

{% block meta_keywords %}direction de transition, management de transition, accompagnement strategique social medico-social sanitaire, pilotage de transition, gouvernance en transition{% endblock %}

{% block og_title %}Solution, Stratégie et Sens | Direction et management de transition{% endblock %}
{% block og_description %}Direction de transition et accompagnement strategique pour les structures sociales, medico-sociales et sanitaires.{% endblock %}

{% block structured_data %}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Solution, Stratégie et Sens",
    "description": "Direction de transition et accompagnement strategique pour les structures sociales, medico-sociales et sanitaires",
    "url": "{{ app.request.schemeAndHttpHost }}",
    "logo": "{{ absolute_url(asset('images/logo/logo.png')) }}",
    "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+33683424012",
        "contactType": "customer service",
        "email": "contact@3s-managers.fr",
        "availableLanguage": "French"
    },
    "areaServed": "FR",
    "serviceType": ["Direction de transition", "Management de transition", "Accompagnement strategique", "Appui managérial"]
}
</script>
{% endblock %}

{% block navbar %}
    {% include 'components/navbar_client.html.twig' %}
{% endblock %}

{% block body %}
<!-- Bannière principale plein écran -->
<section class="hero-banner">
    <div class="hero-overlay"></div>
    <div class="hero-content">
        <p class="hero-subtitle-small">Direction de transition et accompagnement strategique</p>
        <h1 class="hero-title">Management de transition pour vos structures</h1>
        <p class="hero-slogan">Structures sociales, medico-sociales et sanitaires: stabiliser, structurer, transformer</p>
        <a href="{{ path('app_contact') }}" class="btn-appointment">Prendre rendez-vous</a>
    </div>
    <div class="hero-scroll-indicator">
        <i class="fas fa-chevron-down"></i>
    </div>
</section>

<!-- Présentation courte -->
<section class="presentation-section">
    <div class="container">
        <div class="presentation-content">
            <h2>Votre partenaire en transition de direction</h2>
            <p class="lead">Solution, Strategie et Sens accompagne les structures sociales, medico-sociales et sanitaires dans leurs phases de transition, de redressement et de transformation strategique.</p>
            <div class="presentation-grid">
                <div class="presentation-item">
                    <div class="presentation-icon"><i class="fas fa-bullseye" style="color: var(--color-sage);"></i></div>
                    <h3>Direction de transition</h3>
                    <p>Prise de relais, stabilisation de la gouvernance et conduite du changement</p>
                </div>
                <div class="presentation-item">
                    <div class="presentation-icon"><i class="fas fa-handshake" style="color: var(--color-sage);"></i></div>
                    <h3>Management de transition</h3>
                    <p>Leadership operationnel, cadrage des priorites et remobilisation des equipes</p>
                </div>
                <div class="presentation-item">
                    <div class="presentation-icon"><i class="fas fa-balance-scale" style="color: var(--color-sage);"></i></div>
                    <h3>Accompagnement strategique</h3>
                    <p>Pilotage, conformité et trajectoire durable pour vos organisations</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Témoignages -->
<section class="testimonials-section">
    <div class="container">
        <h2>Ils nous font confiance</h2>
        {% if testimonies is not empty %}
        <div class="testimonials-grid">
            {% for testimony in testimonies|slice(0, 3) %}
            <div class="testimonial-card">
                <div class="testimonial-quote">"</div>
                <p class="testimonial-text">{{ testimony.content }}</p>
                <div class="testimonial-author">
                    {% if testimony.imagePath %}
                    <img src="{{ testimony.imagePath }}" alt="{{ testimony.clientName }}" class="author-avatar">
                    {% endif %}
                    <div>
                        <p class="author-name">{{ testimony.clientName }}</p>
                        <p class="author-position">{{ testimony.position ? testimony.position ~ ' - ' : '' }}{{ testimony.organization }}</p>
                    </div>
                </div>
                {% set rating = (testimony.rating|default(0))|round(0, 'floor') %}
                {% set rating = rating < 0 ? 0 : (rating > 5 ? 5 : rating) %}
                <div class="testimonial-rating" title="{{ rating }}/5">
                    {% for i in 1..5 %}
                        <i class="{{ i <= rating ? 'fas' : 'far' }} fa-star"></i>
                    {% endfor %}
                </div>
            </div>
            {% endfor %}
        </div>
        {% else %}
        <p style="text-align:center; color: var(--color-gray-medium);">Aucun témoignage disponible pour le moment.</p>
        {% endif %}
    </div>
</section>

<!-- Webinaires gratuits -->
<section class="webinar-section" id="webinaires">
    <div class="container">
        <div class="webinar-content">
            <div class="webinar-info">
                <h2>Webinaires gratuits</h2>
                <p class="webinar-subtitle">Participez à nos sessions en ligne pour échanger sur les enjeux du secteur</p>
                <ul class="webinar-benefits">
                    <li><i class="fas fa-check" style="color: var(--color-sage);"></i> Sessions interactives de 1h30</li>
                    <li><i class="fas fa-check" style="color: var(--color-sage);"></i> Thématiques actuelles du secteur médico-social</li>
                    <li><i class="fas fa-check" style="color: var(--color-sage);"></i> Questions/réponses avec l'experte</li>
                    <li><i class="fas fa-check" style="color: var(--color-sage);"></i> Certificat de participation</li>
                </ul>
            </div>
            <div class="webinar-upcoming">
                <h3>Prochains webinaires</h3>
                {% if upcoming_webinars is not empty %}
                    {% for webinar in upcoming_webinars|slice(0, 2) %}
                    <div class="webinar-item">
                        <div class="webinar-date">{{ webinar.date|date('d F Y') }}</div>
                        <h4>{{ webinar.name }}</h4>
                        <p>{{ webinar.date|date('H:i') }}{% if webinar.duration %} - {{ webinar.duration }} min{% endif %}</p>
                        <a href="{{ webinar.link }}" target="_blank" class="btn-secondary">S'inscrire</a>
                    </div>
                    {% endfor %}
                {% else %}
                    <p style="color: var(--color-gray-medium);">Aucun webinaire programmé pour le moment. Revenez bientôt !</p>
                {% endif %}
            </div>
        </div>
    </div>
</section>

<!-- Call to action final -->
<section class="cta-section">
    <div class="container">
        <h2>Prêt à transformer votre organisation ?</h2>
        <p>Prenez rendez-vous pour un premier échange confidentiel et sans engagement</p>
        <a href="{{ path('app_contact') }}" class="btn-primary-large">Prendre rendez-vous</a>
    </div>
</section>
{% endblock %}
