{% extends 'base.html.twig' %}

{% block title %}Secteurs d'Intervention | Social, medico-social et sanitaire{% endblock %}

{% block meta_description %}Harmonie & Sens intervient aupres des structures sociales, medico-sociales et sanitaires, avec une expertise forte en transition de direction et management de transition.{% endblock %}

{% block meta_keywords %}secteurs intervention social medico-social sanitaire, management de transition, direction de transition{% endblock %}

{% block og_title %}Secteurs d'Intervention | Harmonie & Sens{% endblock %}
{% block og_description %}Personnes agees, handicap, enfance, sanitaire et insertion : une intervention nationale, claire et ciblee.{% endblock %}

{% block navbar %}
    {% include 'components/navbar_client.html.twig' %}
{% endblock %}

{% block body %}
<section class="service-hero" style="background-image: url('{{ asset('images/backgrounds/banner_test2.jpg') }}');">
    <div class="container">
        <h1>Secteurs d'Intervention</h1>
        <p class="subtitle">Interventions sur tout le territoire national</p>
    </div>
</section>

<section class="service-section blue">
    <div class="container">
        <div class="service-content-flex">
            <div class="service-text">
                <h2>Nos secteurs, en une vue</h2>
                <p>Nous intervenons sur l'ensemble du champ <span class="highlight">social, medico-social et sanitaire</span>, avec une approche de transition de direction, de stabilisation et d'accompagnement strategique.</p>
            </div>
            <div class="service-image">
                <div class="service-icon">
                    <i class="fas fa-network-wired"></i>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="service-section white">
    <div class="container">
        <div class="service-content-flex">
            <div class="service-text">
                <h2>Domaines</h2>
                <div class="service-points">
                    <ul>
                        <li><strong>Personnes agees</strong></li>
                        <li><strong>Handicap</strong></li>
                        <li><strong>Enfance</strong></li>
                        <li><strong>Champ sanitaire</strong></li>
                        <li><strong>Insertion</strong></li>
                    </ul>
                </div>
                <div class="service-cta">
                    <a href="{{ path('app_contact') }}" class="btn-service">Echangeons sur votre secteur</a>
                </div>
            </div>
            <div class="service-image">
                <div class="service-icon">
                    <i class="fas fa-map-marked-alt"></i>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
