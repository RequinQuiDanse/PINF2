{% extends 'admin/base.html.twig' %}

{% block title %}Rendez-vous{% endblock %}

{% block body %}
<div class="admin-content">
    <div class="page-header">
        <h1>Rendez-vous</h1>
        <p>Gérez les demandes de rendez-vous</p>
    </div>

    <div class="table-container">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Date demandée</th>
                    <th>Heure</th>
                    <th>Nom</th>
                    <th>Service</th>
                    <th>Statut</th>
                    <th>Reçu le</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for appointment in appointments %}
                <tr>
                    <td>{{ appointment.desiredDate|date('d/m/Y') }}</td>
                    <td>{{ appointment.desiredTime }}</td>
                    <td>{{ appointment.firstName }} {{ appointment.lastName }}</td>
                    <td>{{ appointment.service }}</td>
                    <td>
                        <span class="badge {{ appointment.statusBadgeClass }}">{{ appointment.statusLabel }}</span>
                    </td>
                    <td>{{ appointment.createdAt|date('d/m/Y H:i') }}</td>
                    <td class="actions">
                        <a href="{{ path('admin_appointment_view', {id: appointment.id}) }}" class="btn btn-sm btn-primary" title="Voir">
                            <i class="fas fa-eye"></i>
                        </a>
                        {% if appointment.isPending %}
                        <a href="{{ path('admin_appointment_confirm', {token: appointment.token}) }}" class="btn btn-sm btn-success" title="Confirmer" onclick="return confirm('Confirmer ce rendez-vous ?')">
                            <i class="fas fa-check"></i>
                        </a>
                        <a href="{{ path('admin_appointment_reject', {token: appointment.token}) }}" class="btn btn-sm btn-danger" title="Refuser">
                            <i class="fas fa-times"></i>
                        </a>
                        {% endif %}
                        <form method="post" action="{{ path('admin_appointment_delete', {id: appointment.id}) }}" style="display:inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ appointment.id) }}">
                            <button class="btn btn-sm btn-danger" onclick="return confirm('Supprimer ce rendez-vous ?')" title="Supprimer">
                                <i class="fas fa-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="7" style="text-align:center;">Aucun rendez-vous</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
